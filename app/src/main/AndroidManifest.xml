<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Speech is fully offline; INTERNET is used ONLY for the explicit, user-initiated model
         browse/download flow (Hugging Face). No network is touched during synthesis. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Background playback (issue #19): PlaybackService keeps synthesis/playback alive with the
         screen off, behind an ongoing notification with Play/Pause/Stop + lock-screen controls. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".PhoneTtsApplication"
        android:allowBackup="false"
        android:label="PhoneTTS"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- "Share to PhoneTTS": receive text shared from any app and load it into the reader. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <!-- "Read aloud" from a text-selection context menu (PROCESS_TEXT). -->
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Automation surface (issue #41): a headless, exported activity that runs one synthesis
             job from an intent (Tasker / MacroDroid / `adb shell am start -a
             com.phonetts.action.SYNTHESIZE`) and returns a result intent. A third consumer of the
             one generation path — no new synthesis logic. -->
        <activity
            android:name=".automation.TtsAutomationActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity="">
            <intent-filter>
                <action android:name="com.phonetts.action.SYNTHESIZE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Foreground service driving background playback + the lock-screen media session
             (com.phonetts.app.playback.PlaybackService). Not exported: only this app binds to
             it. -->
        <service
            android:name=".playback.PlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />
    </application>

</manifest>
