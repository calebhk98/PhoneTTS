<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Speech is fully offline; INTERNET is used ONLY for the explicit, user-initiated model
         browse/download flow (Hugging Face). No network is touched during synthesis. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Issue #4/#5: lets the user point model storage at a real folder on shared/SD-card storage
         (chosen via the Manage screen's Storage Access Framework picker) and have it opened as a
         plain java.io.File, so the :core download/import pipeline needs no SAF-specific code and
         weights SURVIVE an uninstall/reinstall. This is a broad, restricted permission Play would
         reject without special review — acceptable here because PhoneTTS is a personal, sideloaded
         app, never distributed through the Play Store. tools:ignore silences the ScopedStorage lint
         warning that assumes a Play-distributed app. -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Background playback (issue #19): PlaybackService keeps synthesis/playback alive with the
         screen off, behind an ongoing notification with Play/Pause/Stop + lock-screen controls. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- End-of-document haptic cue (issue #32): PlaybackChime's optional vibration pulse. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Issue #77: discover the installed system TextToSpeech engines (Google, Samsung, …) via
         PackageManager. On Android 11+ (API 30) package visibility is filtered, so without this
         <queries> the TTS-service lookup returns nothing and system voices are silently absent. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application
        android:name=".PhoneTtsApplication"
        android:allowBackup="false"
        android:label="PhoneTTS"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- "Share to PhoneTTS": receive text shared from any app and load it into the reader. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <!-- "Read aloud" from a text-selection context menu (PROCESS_TEXT). -->
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Automation surface (issue #41): a headless, exported activity that runs one synthesis
             job from an intent (Tasker / MacroDroid / `adb shell am start -a
             com.phonetts.action.SYNTHESIZE`) and returns a result intent. A third consumer of the
             one generation path — no new synthesis logic. -->
        <activity
            android:name=".automation.TtsAutomationActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity="">
            <intent-filter>
                <action android:name="com.phonetts.action.SYNTHESIZE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Foreground service driving background playback + the lock-screen media session
             (com.phonetts.app.playback.PlaybackService). Not exported: only this app binds to
             it. -->
        <service
            android:name=".playback.PlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Home-screen widget (issue #25): last document title + Play/Pause. Its button fires the
             same PlaybackService action the notification uses. Exported so the launcher can host it. -->
        <receiver
            android:name=".playback.PlaybackWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/playback_widget_info" />
        </receiver>

        <!-- Quick Settings tile (issue #27): toggle play/pause on the last-loaded document from the
             shade. Guarded by the system BIND_QUICK_SETTINGS_TILE permission; exported for the OS. -->
        <service
            android:name=".playback.ResumeTileService"
            android:exported="true"
            android:icon="@drawable/ic_notification"
            android:label="Resume reading"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
    </application>

</manifest>
