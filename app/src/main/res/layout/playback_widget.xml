<?xml version="1.0" encoding="utf-8"?>
<!-- Home-screen widget layout (issue #25): document title + a Play/Pause button. Kept intentionally
     plain (framework colours, framework media icons) so it ships no extra drawables and reads on
     any launcher wallpaper. Wired up in PlaybackWidgetProvider. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/playback_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="#DD202124"
    android:padding="12dp">

    <TextView
        android:id="@+id/playback_widget_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        android:text="PhoneTTS" />

    <ImageButton
        android:id="@+id/playback_widget_play_pause"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Play or pause"
        android:src="@android:drawable/ic_media_play" />

</LinearLayout>
